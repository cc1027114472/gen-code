# Usage: copy this file to .env in the project root, then adjust values for your environment.
# The application loads .env automatically on startup when present.
APP_NAME=llm-trace
APP_ENV=dev
APP_PORT=10008
APP_SHUTDOWN_TIMEOUT=10s

# true enables Gin debug mode and defaults LOG_LEVEL to debug unless explicitly set.
APP_DEBUG=true
APP_TRUSTED_PROXIES=127.0.0.1

# Optional explicit log level. Leave unset to follow APP_DEBUG.
# LOG_LEVEL=debug

# Log HTTP access lines. When false, request ID middleware still runs.
LOG_HTTP_ACCESS=false

# Reserved from your sample for other processes/tools.
LLM_LOG_BODY_MAX=8192
LLM_LOG_ERR_SNIPPET=2048
SOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
MULTI_COMPANY_RZ_RESUME_ON_START=false
